# ===========================================
# OLX Poland Listing Scraper - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# -------------------------------------------
# REQUIRED: Telegram Bot Configuration
# -------------------------------------------
# Get your bot token from @BotFather on Telegram
# https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# -------------------------------------------
# OPTIONAL: Gemini CLI Proxy Configuration
# -------------------------------------------
# URL of the Gemini CLI proxy (gemini_proxy_server.js)
# Default: http://host.docker.internal:3000/ask
GEMINI_PROXY_URL=http://host.docker.internal:3000/ask

# -------------------------------------------
# OPTIONAL: Admin Notifications
# -------------------------------------------
# Your Telegram chat ID for receiving error logs
# Get it by messaging @userinfobot on Telegram
# Leave empty to disable admin logging
ADMIN_CHAT_ID=your_telegram_chat_id_here
